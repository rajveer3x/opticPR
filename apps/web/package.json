  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "clean": "node -e \"import('node:fs/promises').then(({ rm }) => Promise.all([rm('dist', { recursive: true, force: true }), rm('tsconfig.app.tsbuildinfo', { force: true }), rm('tsconfig.node.tsbuildinfo', { force: true })]))\"",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
