generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  githubId     String        @unique
  name         String
  email        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pullRequests PullRequest[]
}

model Repository {
  id           String        @id @default(uuid()) @db.Uuid
  githubRepoId String        @unique
  owner        String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pullRequests PullRequest[]
}

model PullRequest {
  id           String     @id @default(uuid()) @db.Uuid
  githubPrId   String
  number       Int        @default(0)
  title        String
  description  String
  status       String
  riskScore    Int        @default(0)
  reviewStatus String     @default("QUEUED")
  sourceBranch String     @default("")
  targetBranch String     @default("")
  additions    Int        @default(0)
  deletions    Int        @default(0)
  changedFiles Int        @default(0)
  htmlUrl      String     @default("")
  summary      String     @default("")
  issues       Json       @default("[]")
  alerts       Json       @default("[]")
  repositoryId String     @db.Uuid
  authorId     String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  repository   Repository @relation(fields: [repositoryId], references: [id])
  author       User       @relation(fields: [authorId], references: [id])

  @@unique([repositoryId, githubPrId])
}
